# Database
DATABASE_URL=

# NextAuth (auth cliente)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# JWT secrets per auth staff e super-admin (separati da NEXTAUTH_SECRET)
# Genera con: openssl rand -base64 32
STAFF_JWT_SECRET=
ADMIN_JWT_SECRET=

# Google OAuth (clienti)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (account piattaforma)
STRIPE_SECRET_KEY=
# Webhook platform (ordini legacy pre-Connect): endpoint /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# Webhook Connect ("Listen to events on connected accounts"):
# endpoint /api/webhooks/stripe-connect
STRIPE_CONNECT_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Email di contatto commerciale mostrata nella CTA della homepage
NEXT_PUBLIC_CONTACT_EMAIL=info@example.com

# Cron Vercel (email giornaliera corrispettivi): Vercel invia
# "Authorization: Bearer $CRON_SECRET" alle route /api/cron/*
CRON_SECRET=

# ── Wallet (OPZIONALI: senza queste env i bottoni non compaiono) ─────────────
# Apple Wallet: serve un Pass Type ID + certificato dal portale Apple Developer
# (Certificates, Identifiers & Profiles → Identifiers → Pass Type IDs).
# Esporta il certificato dal portachiavi in .p12 INCLUDENDO il certificato
# intermedio "Apple Worldwide Developer Relations" (seleziona entrambi), poi:
#   base64 -i certificato.p12 | tr -d '\n'
APPLE_PASS_CERT_BASE64=
APPLE_PASS_CERT_PASSWORD=
# Team ID (Membership) e identificatore del Pass Type (es. pass.com.klink.ticket)
APPLE_TEAM_ID=
APPLE_PASS_TYPE_ID=
# Google Wallet: crea un issuer su https://pay.google.com/business/console
# (Google Wallet API) e un service account su Google Cloud con ruolo
# "Wallet Object Issuer"; scarica la chiave JSON e codificala:
#   base64 -i service-account.json | tr -d '\n'
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_KEY_BASE64=

# ── Modulo fiscale (OPZIONALE: senza queste env è globalmente spento) ────────
# Token dell'API "Fatturazione e Scontrini Elettronici" di Openapi
# (console.openapi.com → token con scope IT-receipts). Sandbox: "true" usa
# test.invoice.openapi.com (AdE simulata, nessuna credenziale reale).
OPENAPI_FISCAL_API_KEY=
OPENAPI_FISCAL_SANDBOX=true
# Chiave per cifrare (AES-GCM) gli eventuali segreti dentro fiscalConfig
FISCAL_CONFIG_ENCRYPTION_KEY=
