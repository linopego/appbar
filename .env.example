# Database
DATABASE_URL=

# NextAuth (auth cliente)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# JWT secrets per auth staff e super-admin (separati da NEXTAUTH_SECRET)
# Genera con: openssl rand -base64 32
STAFF_JWT_SECRET=
ADMIN_JWT_SECRET=

# Google OAuth (clienti)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (account piattaforma)
STRIPE_SECRET_KEY=
# Webhook platform (ordini legacy pre-Connect): endpoint /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# Webhook Connect ("Listen to events on connected accounts"):
# endpoint /api/webhooks/stripe-connect
STRIPE_CONNECT_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Email di contatto commerciale mostrata nella CTA della homepage
NEXT_PUBLIC_CONTACT_EMAIL=info@example.com

# Cron Vercel (email giornaliera corrispettivi): Vercel invia
# "Authorization: Bearer $CRON_SECRET" alle route /api/cron/*
CRON_SECRET=
