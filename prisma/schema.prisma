generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ORGANIZATION (tenant della piattaforma)
// =====================================================

model Organization {
  id              String   @id @default(cuid())
  name            String
  // Account Stripe Connect collegato (null finché l'onboarding non è completato)
  stripeAccountId String?  @unique
  // Flag sincronizzati dal webhook Connect account.updated
  stripeChargesEnabled   Boolean @default(false)
  stripeDetailsSubmitted Boolean @default(false)
  // Percentuale trattenuta dalla piattaforma sulle vendite (es. 5.00 = 5%)
  feePercent      Decimal  @default(0) @db.Decimal(5, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  venues     Venue[]
  adminUsers AdminUser[]
}

// =====================================================
// VENUE & LISTINO
// =====================================================

model Venue {
  id                    String   @id @default(cuid())
  organizationId        String
  name                  String
  slug                  String   @unique
  active                Boolean  @default(true)
  refundBlockedWindows  Json? // [{ day: 0-6, startHour: 22, startMin: 0, endHour: 6, endMin: 0 }]
  refundBlockedTimezone String   @default("Europe/Rome")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  priceTiers   PriceTier[]
  operators    Operator[]
  orders       Order[]
  tickets      Ticket[]

  @@index([organizationId])
}

model PriceTier {
  id        String   @id @default(cuid())
  venueId   String
  name      String // "Acqua", "Analcolico", "Birra", "Red Bull", "Drink", "Drink Premium"
  price     Decimal  @db.Decimal(10, 2)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue      Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tickets    Ticket[]
  orderItems OrderItem[]

  @@unique([venueId, name])
  @@index([venueId, active])
}

// =====================================================
// CLIENTI (NextAuth-compatible)
// =====================================================

model Customer {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  firstName     String?
  lastName      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // soft-delete GDPR

  accounts CustomerAccount[]
  sessions CustomerSession[]
  orders   Order[]
  tickets  Ticket[]

  @@index([email])
  @@map("users")
}

// Tabelle NextAuth standard, prefissate "Customer" per separarle dal resto
model CustomerAccount {
  id                String  @id @default(cuid())
  customerId        String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model CustomerSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  customerId   String
  expires      DateTime
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =====================================================
// ORDINI & TICKET
// =====================================================

model Order {
  id              String      @id @default(cuid())
  customerId      String
  venueId         String
  totalAmount     Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  stripeSessionId String      @unique
  stripePaymentId String?
  // Connected account Stripe su cui è avvenuto l'addebito (direct charge);
  // null = ordine legacy pre-Connect, addebitato sull'account piattaforma
  stripeAccountId String?
  // Snapshot della application fee trattenuta dalla piattaforma (EUR)
  platformFeeAmount Decimal @default(0) @db.Decimal(10, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paidAt          DateTime?

  customer Customer    @relation(fields: [customerId], references: [id])
  venue    Venue       @relation(fields: [venueId], references: [id])
  tickets  Ticket[]
  refunds  Refund[]
  items    OrderItem[]

  @@index([customerId, createdAt])
  @@index([venueId, createdAt])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  priceTierId String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  tierName    String
  createdAt   DateTime @default(now())

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  priceTier PriceTier @relation(fields: [priceTierId], references: [id])

  @@index([orderId])
}

model Ticket {
  id          String       @id @default(cuid())
  orderId     String
  customerId  String
  venueId     String
  priceTierId String
  qrToken     String       @unique // UUID v4
  status      TicketStatus @default(ACTIVE)
  expiresAt   DateTime
  consumedAt  DateTime?
  consumedBy  String? // operatorId
  refundedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  order     Order     @relation(fields: [orderId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  venue     Venue     @relation(fields: [venueId], references: [id])
  priceTier PriceTier @relation(fields: [priceTierId], references: [id])
  operator  Operator? @relation(fields: [consumedBy], references: [id])

  @@index([qrToken])
  @@index([customerId, status])
  @@index([venueId, status])
  @@index([orderId])
  @@index([expiresAt])
}

model Refund {
  id              String           @id @default(cuid())
  orderId         String
  amount          Decimal          @db.Decimal(10, 2)
  ticketIds       String[]
  reason          String           @db.Text
  customerNote    String?          @db.Text
  managerNote     String?          @db.Text
  stripeRefundId  String?          @unique
  status          RefundStatus     @default(PENDING)
  errorMessage    String?          @db.Text // ultimo errore Stripe quando status = FAILED
  requestedAt     DateTime         @default(now())
  processedAt     DateTime?
  processedBy     String? // operator.id o adminUser.id; tipo distinto in processedByType
  processedByType ProcessedByType?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// =====================================================
// STAFF (operatori al banco)
// =====================================================

model Operator {
  id          String       @id @default(cuid())
  venueId     String
  name        String
  email       String? // obbligatoria (validazione applicativa) per i MANAGER
  pinHash     String // bcrypt — login PIN al banco, tutti i ruoli
  // Login email+password del pannello: valorizzata SOLO per i MANAGER
  passwordHash       String?
  mustChangePassword Boolean @default(false)
  role        OperatorRole
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lastLoginAt DateTime?

  venue     Venue           @relation(fields: [venueId], references: [id])
  tickets   Ticket[]
  auditLogs AdminAuditLog[]

  @@index([venueId, active])
}

// =====================================================
// SUPER-ADMIN (cross-venue)
// =====================================================

// Regola di integrità (applicativa, validata con Zod alla creazione/modifica):
// role PLATFORM  ⇒ organizationId null
// role ORG_ADMIN ⇒ organizationId obbligatorio
enum AdminRole {
  PLATFORM // admin della piattaforma: vede e gestisce tutte le organizzazioni
  ORG_ADMIN // admin di una singola organizzazione
}

model AdminUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  name               String
  role               AdminRole @default(ORG_ADMIN)
  organizationId     String?
  totpSecret         String?
  totpEnabled        Boolean   @default(false)
  mustChangePassword Boolean   @default(false)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastLoginAt        DateTime?

  organization Organization?   @relation(fields: [organizationId], references: [id])
  auditLogs    AdminAuditLog[]

  @@index([organizationId])
}

model AdminAuditLog {
  id             String    @id @default(cuid())
  adminUserId    String?
  operatorId     String?
  // Denormalizzato: organizzazione dell'azione quando determinabile (dal venue
  // dell'operatore o dall'admin ORG_ADMIN); null per azioni PLATFORM senza org.
  organizationId String?
  actorType      ActorType @default(ADMIN_USER)
  action      String // "REFUND_APPROVED", "TICKET_INVALIDATED", "OPERATOR_CREATED", ecc.
  targetType  String? // "Ticket", "Order", "Operator", "Venue", "PriceTier"
  targetId    String?
  payload     Json? // snapshot del contesto
  ipAddress   String?
  userAgent   String?   @db.Text
  createdAt   DateTime  @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id])
  operator  Operator?  @relation(fields: [operatorId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([operatorId, createdAt])
  @@index([organizationId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}

// =====================================================
// STRIPE EVENT TRACKING (idempotency)
// =====================================================

model StripeEvent {
  id          String   @id // event.id di Stripe
  type        String
  processedAt DateTime @default(now())
  payload     Json

  @@index([type, processedAt])
}

// =====================================================
// ENUMS
// =====================================================

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TicketStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSING
  APPROVED
  COMPLETED
  FAILED
  REJECTED
}

enum OperatorRole {
  BARISTA
  CASSIERE
  MANAGER
}

enum ProcessedByType {
  OPERATOR
  ADMIN_USER
  SYSTEM
}

enum ActorType {
  ADMIN_USER
  OPERATOR
  SYSTEM
}

model EmailLog {
  id           String      @id @default(cuid())
  to           String
  subject      String
  template     String
  resendId     String?
  status       EmailStatus @default(SENT)
  errorMessage String?     @db.Text
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([to, createdAt])
  @@index([template, createdAt])
  @@index([status, createdAt])
}

enum EmailStatus {
  SENT
  FAILED
  BOUNCED
}
